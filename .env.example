# Supabase client configuration
# Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# Optional canonical site origin used when auth emails are generated outside
# the active browser session. Leave unset for local-only development.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Legacy public key name (optional fallback during migration)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-legacy-anon-key-here

# Legacy Vite-compatible names (optional fallback during local migration)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-legacy-anon-key-here
