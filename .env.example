# Firebase configuration for the current auth/cloud data path.
# Copy to .env.local (preferred) or .env for local development.
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# Optional public support contact used by the v0.7.1 communication template pack.
NEXT_PUBLIC_SUPPORT_EMAIL=life.customer.support@gmail.com

# Optional canonical site origin used when auth emails are generated outside
# the active browser session. Leave unset for local-only development.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Legacy Supabase keys are still optional for older modules that have not yet
# been migrated away from Supabase storage or messaging.
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here
