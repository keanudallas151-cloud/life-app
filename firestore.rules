rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isConversationParticipant(conversationId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/conversations/$(conversationId))
        && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participant_ids;
    }

    function hasValidQueuedEmailMessage() {
      return request.resource.data.message is map
        && request.resource.data.message.keys().hasAll(['subject'])
        && request.resource.data.message.subject is string
        && request.resource.data.message.subject.size() > 0
        && request.resource.data.message.subject.size() <= 160
        && request.resource.data.message.keys().hasAny(['text', 'html'])
        && (!request.resource.data.message.keys().hasAny(['text'])
          || request.resource.data.message.text is string)
        && (!request.resource.data.message.keys().hasAny(['html'])
          || request.resource.data.message.html is string);
    }

    function isWelcomeConfirmedMail() {
      return request.resource.data.template_key == 'welcomeConfirmed'
        && request.resource.data.toUids is list
        && request.resource.data.toUids.size() == 1
        && request.resource.data.toUids[0] == request.auth.uid
        && request.resource.data.replyTo == 'life.customer.support@gmail.com';
    }

    function isSupportAcknowledgementMail() {
      return request.resource.data.template_key == 'supportAcknowledgement'
        && request.resource.data.keys().hasAll(['source_request_id'])
        && request.resource.data.source_request_id is string
        && request.resource.data.toUids is list
        && request.resource.data.toUids.size() == 1
        && request.resource.data.toUids[0] == request.auth.uid
        && request.resource.data.replyTo == 'life.customer.support@gmail.com'
        && exists(/databases/$(database)/documents/supportRequests/$(request.resource.data.source_request_id))
        && get(/databases/$(database)/documents/supportRequests/$(request.resource.data.source_request_id)).data.user_id == request.auth.uid;
    }

    function isNewMessageMail() {
      return request.resource.data.template_key == 'newMessage'
        && request.resource.data.keys().hasAll(['conversation_id', 'recipient_user_id'])
        && request.resource.data.conversation_id is string
        && request.resource.data.recipient_user_id is string
        && request.resource.data.toUids is list
        && request.resource.data.toUids.size() == 1
        && request.resource.data.toUids[0] == request.resource.data.recipient_user_id
        && request.resource.data.recipient_user_id != request.auth.uid
        && request.resource.data.replyTo == 'life.customer.support@gmail.com'
        && exists(/databases/$(database)/documents/conversations/$(request.resource.data.conversation_id))
        && request.auth.uid in get(/databases/$(database)/documents/conversations/$(request.resource.data.conversation_id)).data.participant_ids
        && request.resource.data.recipient_user_id in get(/databases/$(database)/documents/conversations/$(request.resource.data.conversation_id)).data.participant_ids;
    }

    match /profiles/{userId} {
      allow read: if isOwner(userId)
        || (isSignedIn() && resource.data.profile_completed == true);
      allow create, update: if isOwner(userId)
        && request.resource.data.user_id == request.auth.uid;
      allow delete: if false;
    }

    match /userData/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId)
        && request.resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    match /userPrivate/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId)
        && request.resource.data.user_id == request.auth.uid
        && request.resource.data.email is string
        && request.resource.data.email.size() > 3;
      allow delete: if false;
    }

    match /supportRequests/{requestId} {
      allow read: if isSignedIn() && resource.data.user_id == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.user_id == request.auth.uid
        && request.resource.data.email is string
        && request.resource.data.email.size() > 3
        && request.resource.data.subject is string
        && request.resource.data.subject.size() > 2
        && request.resource.data.subject.size() <= 120
        && request.resource.data.message_text is string
        && request.resource.data.message_text.size() > 10
        && request.resource.data.message_text.size() <= 4000;
      allow update, delete: if false;
    }

    match /mail/{mailId} {
      allow read, update, delete: if false;
      allow create: if isSignedIn()
        && request.resource.data.created_by_user_id == request.auth.uid
        && hasValidQueuedEmailMessage()
        && (
          isWelcomeConfirmedMail()
          || isSupportAcknowledgementMail()
          || isNewMessageMail()
        );
    }

    match /quizStats/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId)
        && request.resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    match /investorProfiles/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId)
        && request.resource.data.user_id == request.auth.uid;
      allow delete: if false;
    }

    match /inventorProfiles/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId)
        && request.resource.data.user_id == request.auth.uid;
      allow delete: if false;
    }

    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn()
        && (
          (resource.data.userId == request.auth.uid
            && request.resource.data.userId == request.auth.uid)
          || (
            request.resource.data.userId == resource.data.userId
            && request.resource.data.author == resource.data.author
            && request.resource.data.authorAvatarUrl == resource.data.authorAvatarUrl
            && request.resource.data.title == resource.data.title
            && request.resource.data.body == resource.data.body
            && request.resource.data.flair == resource.data.flair
            && request.resource.data.createdAt == resource.data.createdAt
            && request.resource.data.diff(resource.data).changedKeys().hasOnly([
              'voteCount',
              'updatedAt'
            ])
          )
        );
      allow delete: if false;
    }

    match /comments/{commentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    match /postVotes/{voteId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create, update: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    match /swipes/{swipeId} {
      allow read: if isSignedIn()
        && (
          resource.data.from_user_id == request.auth.uid
          || resource.data.to_user_id == request.auth.uid
        );
      allow create, update: if isSignedIn()
        && request.resource.data.from_user_id == request.auth.uid;
      allow delete: if false;
    }

    match /blockedUsers/{blockId} {
      allow read: if isSignedIn()
        && (
          resource.data.blocker_user_id == request.auth.uid
          || resource.data.blocked_user_id == request.auth.uid
        );
      allow create, update: if isSignedIn()
        && request.resource.data.blocker_user_id == request.auth.uid;
      allow delete: if false;
    }

    match /reportedProfiles/{reportId} {
      allow create: if isSignedIn()
        && request.resource.data.reporter_user_id == request.auth.uid;
      allow read, update, delete: if false;
    }

    match /conversations/{conversationId} {
      allow read: if isSignedIn()
        && request.auth.uid in resource.data.participant_ids;
      allow create: if isSignedIn()
        && request.auth.uid in request.resource.data.participant_ids
        && request.resource.data.participant_ids.size() == 2;
      allow update: if isSignedIn()
        && request.auth.uid in resource.data.participant_ids
        && request.resource.data.participant_ids == resource.data.participant_ids;
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isConversationParticipant(conversationId);
        allow create: if isConversationParticipant(conversationId)
          && request.resource.data.sender_user_id == request.auth.uid;
        allow update, delete: if false;
      }
    }
  }
}
